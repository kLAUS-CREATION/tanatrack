# ============================================================================
# ADMIN (Vercel) — production environment variables
# Same backend as the client. Set in Vercel → admin project → Env Vars.
# NEXT_PUBLIC_* is inlined at build time — set before building.
# ============================================================================

# Must end with /api, no trailing slash. Add the admin's Vercel URL to the
# backend's FRONTEND_URL (comma-separated) so its origin passes CORS too.
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com/api
