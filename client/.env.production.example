# ============================================================================
# CLIENT (Vercel) — production environment variables
# Add in Vercel → Project → Settings → Environment Variables (Production).
# IMPORTANT: NEXT_PUBLIC_* vars are inlined AT BUILD TIME. Set this BEFORE the
# first build; if you change it later you must redeploy.
# ============================================================================

# Backend REST base URL — MUST end with /api and have NO trailing slash.
# The socket provider derives the socket host by stripping the /api suffix,
# so this single var drives both REST calls and the notifications socket.
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com/api
