// --- CHANGE APPROVAL (maker–checker) — products, categories, suppliers, … ---

enum ChangeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ChangeEntity {
  PRODUCT
  VARIANT
  CATEGORY
  SUPPLIER
  PURCHASE
  STOCK_MOVE
}

enum ChangeOp {
  CREATE
  UPDATE
  DELETE
}

// Doubles as the approval queue AND the audit log across every maker-checker
// domain. A manager-permission member's action lands here as PENDING (mutates
// nothing until approved); an Owner / ADMINISTRATION_ACCESS member's action is
// applied instantly and recorded here as already-APPROVED. requestedBy/reviewedBy
// are raw userIds (no FK), matching the StockMovement ledger pattern; names are
// resolved at read time.
model ChangeRequest {
  id             String       @id @default(cuid())
  organizationId String
  entity         ChangeEntity
  operation      ChangeOp
  productId      String? // product target, or the variant's parent product
  variantId      String? // variant target (UPDATE/DELETE)
  categoryId     String? // category target (UPDATE/DELETE)
  supplierId     String? // supplier target (UPDATE/DELETE)
  payload        Json? // the create/update DTO snapshot; null for DELETE
  status         ChangeStatus @default(PENDING)
  requestedBy    String // userId — who requested / acted
  reviewedBy     String? // userId of the approver
  reviewedAt     DateTime?
  reason         String? // rejection reason / note
  appliedRefId   String? // id of the row created/affected when applied
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([requestedBy])
  @@map("change_request")
}
