generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  emailVerified Boolean      @default(false)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  role          String       @default("USER")
  banned        Boolean?
  banReason     String?
  banExpires    DateTime?
  accounts      Account[]
  memberships   Membership[]
  sessions      Session[]

  @@map("user")
}

model Session {
  id             String   @id @default(cuid())
  userId         String
  token          String   @unique
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id           String        @id @default(cuid())
  name         String
  isActive     Boolean       @default(true)
  logoUrl      String?
  timeZone     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  metadata     Json?
  invites      Invite[]
  invoices     Invoice[]
  memberships  Membership[]
  roles        Role[]
  subscription Subscription?

  @@map("organization")
}

model Role {
  id             String           @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  memberships    Membership[]
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions    RolePermission[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("role")
}

model PermissionDefinition {
  id          String           @id @default(cuid())
  slug        String           @unique
  name        String
  description String           @default("")
  category    FeatureCategory
  action      String
  roles       RolePermission[]

  @@map("permission_definition")
}

model RolePermission {
  roleId                 String
  permissionDefinitionId String
  allowed                Boolean              @default(false)
  permissionDefinition   PermissionDefinition @relation(fields: [permissionDefinitionId], references: [id], onDelete: Cascade)
  role                   Role                 @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionDefinitionId])
  @@map("role_permission")
}

model Membership {
  id             String           @id @default(cuid())
  userId         String
  organizationId String
  roleId         String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  roleType       OrganizationRole @default(ADMIN)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role?            @relation(fields: [roleId], references: [id])
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@index([roleId])
  @@map("membership")
}

model Invite {
  id             String           @id @default(cuid())
  email          String
  organizationId String
  roleId         String?
  roleType       OrganizationRole @default(ADMIN)
  token          String           @unique
  expiresAt      DateTime
  status         InviteStatus     @default(PENDING)
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email])
  @@map("invite")
}

model Plan {
  id            String         @id @default(cuid())
  slug          String         @unique
  name          String
  description   String?
  badge         String?
  sortOrder     Int
  type          PlanType
  currency      String         @default("ETB")
  monthlyPrice  Int?
  yearlyPrice   Int?
  trialDays     Int?           @default(0)
  isActive      Boolean        @default(true)
  isPublic      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  addOns        AddOn[]
  planFeatures  PlanFeature[]
  subscriptions Subscription[]

  @@index([slug, isActive, isPublic, sortOrder])
  @@map("plan")
}

model Feature {
  id           String           @id @default(cuid())
  key          String           @unique
  name         String
  description  String?
  type         FeatureType
  category     FeatureCategory?
  planFeatures PlanFeature[]

  @@map("feature")
}

model PlanFeature {
  planId              String
  featureId           String
  value               String
  overrideDescription String?
  feature             Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  plan                Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@id([planId, featureId])
  @@map("plan_feature")
}

model AddOn {
  id            String  @id @default(cuid())
  slug          String  @unique
  name          String
  description   String?
  monthlyPrice  Int
  yearlyPrice   Int?
  linkedFeature String?
  maxQuantity   Int?    @default(1)
  planId        String?
  plan          Plan?   @relation(fields: [planId], references: [id])

  @@map("add_on")
}

model Subscription {
  id                 String             @id @default(cuid())
  organizationId     String             @unique
  planId             String
  status             SubscriptionStatus
  trialEndsAt        DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)
  billingInterval    BillingInterval
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  invoices           Invoice[]
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan               Plan               @relation(fields: [planId], references: [id])

  @@index([organizationId])
  @@index([planId])
  @@map("subscription")
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  subscriptionId String
  amount         Int
  currency       String        @default("ETB")
  status         InvoiceStatus
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id])

  @@index([organizationId])
  @@map("invoice")
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum OrganizationRole {
  OWNER
  ADMIN
}

enum PlanType {
  FREE
  PAID
}

enum FeatureType {
  BOOLEAN
  NUMBER
  LIST
}

enum FeatureCategory {
  AI
  INVENTORY
  PRODUCTS
  SALES
  WAREHOUSING
  ORDERS
  PURCHASE
  SUPPLIERS
  REPORTS
  CUSTOMERS
  USERS
  HELP
}

enum SubscriptionStatus {
  ACTIVE
  ONFREETRIAL
  PENDING
  EXPIRED
  CANCELED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}
