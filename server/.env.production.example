# ============================================================================
# SERVER (Render) — production environment variables
# Copy each key/value into Render → your Web Service → Environment.
# Do NOT commit real secrets. This file is a template only.
# ============================================================================

# --- App ---------------------------------------------------------------------
NODE_ENV=production
# PORT: DO NOT SET. Render injects PORT automatically and your code already
# reads `process.env.PORT ?? 5500`. Setting it yourself can break routing.

# --- Database ----------------------------------------------------------------
# Render Postgres: use the INTERNAL connection string (same region, no SSL needed).
# External (Neon/Supabase): use the POOLED string and append ?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# --- Authentication (better-auth) -------------------------------------------
# Generate a fresh secret:  openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
# The PUBLIC https URL of THIS backend on Render (no trailing slash).
# NOTE: code reads BETTER_AUTH_URL — your old BETTER_AUTH_BASE_URL was never used.
BETTER_AUTH_URL=https://your-backend.onrender.com

# --- Cross-origin (Vercel frontend) -----------------------------------------
# Used by corsOrigins() for REST CORS + the socket.io gateway.
# Comma-separated if you have more than one (e.g. client + admin).
FRONTEND_URL=https://your-frontend.vercel.app

# Emails (colon-separated) that are auto-promoted to ADMIN role on signup.
OWNER_EMAILS=you@example.com

# --- Email: Gmail OAuth2 (this is what actually sends OTP/verification mail) -
FROM_EMAIL=your-sender@gmail.com
FROM_NAME=Tana Track
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# --- Optional / referenced but currently inactive ---------------------------
# ARIFPAY (payments) — only needed once you wire up Arifpay.
ARIFPAY_API_KEY=
ARIFPAY_EXPIRATION=2027-02-01T03:45:27
# SMTP MailerModule block — unused unless you switch off Gmail OAuth. Leave blank.
EMAIL_HOST=
EMAIL_USERNAME=
EMAIL_PASSWORD=
